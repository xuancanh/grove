# Grove runs fully OFFLINE by default: no login, no server, data in
# IndexedDB on the device. AI features work when the user adds their own
# provider key in Settings (calls go straight to the provider).

# Optional LOOM BRIDGE (offline app): lets the user connect their Knowledge
# Loom account to push notes & cards into their vault. Server mode needs none
# of this — it's connected by definition.
#VITE_LOOM_API=https://app.your-loom-host.com
#VITE_SUPABASE_URL=
#VITE_SUPABASE_ANON_KEY=

# Optional SERVER MODE — build against the hosted Knowledge Loom enterprise
# backend (/api/grove) with shared Supabase auth:
#VITE_GROVE_SERVER=1
#VITE_SUPABASE_URL=
#VITE_SUPABASE_ANON_KEY=
#GROVE_API=http://localhost:8787   # dev proxy target for /api
