# Grove frontend (the API lives in the Knowledge Loom enterprise backend).

# Dev: where `npm run dev` proxies /api (a running knowledge-loom-ee server).
GROVE_API=http://localhost:8787

# Auth (production / multi-user): same Supabase project as Knowledge Loom.
# Leave unset for local single-user mode (no login screen).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
